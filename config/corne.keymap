 * SPDX-License-Identifier: MIT
 *
 * CORNE / SKELETYL — PT-BR ABNT2 KEYMAP
 *
 * Physical layout : 3×5+3 split, 42 keys
 * OS layout       : PT-BR ABNT2  (must be selected in OS settings)
 *
 * ┌──────────────────────────────────────────────────────────────┐
 * │  Layer map                                                   │
 * │    0  Base   QWERTY · home-row mods · ç on right pinky      │
 * │    1  Num    numbers · shifted symbols · { } [ ]            │
 * │    2  Sym    operators · PT-BR dead keys                     │
 * │    3  Fn     F1-F12 · arrows · bootloader                    │
 * │    4  BT     Bluetooth select · output toggle                │
 * ├──────────────────────────────────────────────────────────────┤
 * │  PT-BR dead keys  (Sym layer = hold BKSP)                    │
 * │    ]  position  →  ´ dead acute     á é í ó ú              │
 * │    `  position  →  ` dead grave     à                       │
 * │    ~  position  →  ^ dead circ      â ê ô                   │
 * │    Ç  hold      →  ~ dead tilde     ã õ   (base layer)      │
 * ├──────────────────────────────────────────────────────────────┤
 * │  Key grid (combo position reference)                         │
 * │   Row 0:  Q=1  W=2  E=3  R=4  T=5    Y=6  U=7  I=8  O=9  P=10  │
 * │   Row 1:  A=13 S=14 D=15 F=16 G=17   H=18 J=19 K=20 L=21 Ç=22  │
 * │   Row 2:  Z=25 X=26 C=27 V=28 B=29   B=30 N=31 M=32 ,=33 .=34  │
 * │   Thumb:  TAB=36 SPC=37 SFT=38        BSP=39 ENT=40 BSP=41      │
 * └──────────────────────────────────────────────────────────────┘
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include "keys_pt_abnt2.h"

/ {
    /* ─────────────────────────────────────────────────────────────
     * BEHAVIORS
     * ───────────────────────────────────────────────────────────── */

    behaviors {

        /* tap = character  ·  hold = modifier */
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&kp>;
        };

        /* single tap = (  ·  double tap = ) */
        td_paren: tap_dance_paren {
            compatible = "zmk,behavior-tap-dance";
            label = "TAP_DANCE_PAREN";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp LPAR>, <&kp RPAR>;
        };

        /* single tap = [  ·  double tap = ] */
        td_bkt: tap_dance_bracket {
            compatible = "zmk,behavior-tap-dance";
            label = "TAP_DANCE_BRACKET";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp PT_LBKT>, <&kp PT_RBKT>;
        };

        /* single tap = {  ·  double tap = } */
        td_brc: tap_dance_brace {
            compatible = "zmk,behavior-tap-dance";
            label = "TAP_DANCE_BRACE";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp PT_LBRC>, <&kp PT_RBRC>;
        };
    };

    /* ─────────────────────────────────────────────────────────────
     * COMBOS
     *   Q+W  (1+2)   → Esc
     *   P+Ç  (10+22) → Delete
     *   Q+A  (12+13) → Caps Lock
     * ───────────────────────────────────────────────────────────── */

    combos {
        compatible = "zmk,combos";

        esc {
            bindings = <&kp ESC>;
            key-positions = <1 2>;
        };

        del {
            bindings = <&kp DELETE>;
            key-positions = <10 22>;
        };

        caps {
            bindings = <&kp CAPS>;
            key-positions = <12 13>;
        };
    };

    /* ─────────────────────────────────────────────────────────────
     * KEYMAP
     * ───────────────────────────────────────────────────────────── */

    keymap {
        compatible = "zmk,keymap";

        /* ══════════════════════════════════════════════════════════
         * LAYER 0 — BASE
         *
         *  Q    W    E    R    T  │  Y    U    I    O    P
         *  A    S    D    F    G  │  H    J  K/Ctl  L   Ç/~
         *  Z    X    C    V    B  │  B    N    M   ,/\  .//
         *  Z hold → GUI              Ç hold → ~ dead tilde (ã õ)
         *
         *       [4]  [1]  SFT  │  [2]  [3]  BSP
         *       TAB  SPC       │  BSP  ENT
         * ══════════════════════════════════════════════════════════ */

        default_layer {
            bindings = <
&none  &kp Q           &kp W  &kp E      &kp R        &kp T             &kp Y            &kp U        &kp I                  &kp O                   &kp P                      &none
&none  &kp A           &kp S  &kp D      &kp F        &kp G             &kp H            &kp J        &hm RIGHT_CONTROL K    &kp L                   &hm PT_TILDE PT_C_CEDILLA  &none
&none  &hm LEFT_GUI Z  &kp X  &kp C      &kp V        &kp B             &kp B            &kp N        &kp M                  &hm PT_BACKSLASH COMMA  &hm PT_SLASH PERIOD        &none
                              &lt 4 TAB  &lt 1 SPACE  &kp LEFT_SHIFT    &lt 2 BACKSPACE  &lt 3 ENTER  &kp BACKSPACE
            >;
        };

        /* ══════════════════════════════════════════════════════════
         * LAYER 1 — NUMBERS  (hold SPC)
         *
         *  1    2    3    4    5  │  6    7    8    9    0
         *  !    @    #    $    %  │  ^    &    *    (    )
         *  =    -    +    {    }  │  [    ]    ;    :   \/
         *       ___  ___  ___  │  ___  ___  ___
         *
         * All symbol keycodes use PT_* for correct ABNT2 output.
         * ══════════════════════════════════════════════════════════ */

        lower_layer {
            bindings = <
&none  &kp N1           &kp N2     &kp N3    &kp N4       &kp N5       &kp N6           &kp N7         &kp N8        &kp N9                &kp N0                 &none
&none  &kp EXCLAMATION  &kp AT     &kp HASH  &kp DOLLAR   &kp PERCENT  &kp PT_CARET     &kp AMPERSAND  &kp ASTERISK  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &none
&none  &kp EQUAL        &kp MINUS  &kp PLUS  &kp PT_LBRC  &kp PT_RBRC  &kp PT_LBKT      &kp PT_RBKT    &kp PT_SEMI   &kp PT_COLON          &hm PT_BACKSLASH PT_SLASH  &none
                                   &trans    &trans       &trans       &trans           &trans         &trans
            >;
        };

        /* ══════════════════════════════════════════════════════════
         * LAYER 2 — SYMBOLS  (hold BKSP)
         *
         *  !    @    #    $    %  │  ^    &    *    (    )
         *  |    _    -    =    +  │  {    }    [    ]    ´
         *  `    ^    \    <    >  │  ?    "    :    ;    .
         *                         │       /    '
         *
         * PT-BR dead keys:
         *   ´  dead acute  (row 1 last)  →  á é í ó ú
         *   `  dead grave  (row 2 first) →  à
         *   ^  dead circ   (row 2 + top) →  â ê ô
         *   ~  dead tilde  (base hold)   →  ã õ
         * ══════════════════════════════════════════════════════════ */

        raise_layer {
            bindings = <
&none  &kp EXCL       &kp AT       &kp HASH          &kp DLLR   &kp PRCNT    &kp PT_CARET  &kp AMPS      &kp ASTRK     &kp LPAR     &kp RPAR      &none
&none  &kp PT_PIPE    &kp UNDER    &kp MINUS         &kp EQUAL  &kp PLUS     &kp PT_LBRC   &kp PT_RBRC   &kp PT_LBKT   &kp PT_RBKT  &kp PT_ACUTE  &none
&none  &kp PT_GRAVE   &kp PT_CARET &kp PT_BACKSLASH  &kp LT     &kp GT       &kp PT_QMARK  &kp PT_DQT    &kp PT_COLON  &kp PT_SEMI  &kp DOT       &none
                                   &trans            &trans     &trans       &trans        &kp PT_SLASH  &kp PT_SQT
            >;
        };

        /* ══════════════════════════════════════════════════════════
         * LAYER 3 — FUNCTION KEYS  (hold ENT)
         *
         *  F1   F2   F3   F4   F5  │  _    _    ↑    _    _
         *  F6   F7   F8   F9  F10  │  _    ←    ↓    →    _
         * F11  F12   _    _    _   │  _    _    _    _    _
         *             _    _    _  │  _    _   BOOT
         * ══════════════════════════════════════════════════════════ */

        adjust_layer {
            bindings = <
&none  &kp F1   &kp F2   &kp F3  &kp F4  &kp F5    &trans  &trans          &kp UP_ARROW    &trans      &trans  &none
&none  &kp F6   &kp F7   &kp F8  &kp F9  &kp F10   &trans  &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT   &trans  &none
&none  &kp F11  &kp F12  &trans  &trans  &trans    &trans  &trans          &trans          &trans      &trans  &none
                         &trans  &trans  &trans    &trans  &trans          &bootloader
            >;
        };

        /* ══════════════════════════════════════════════════════════
         * LAYER 4 — BLUETOOTH  (hold TAB)
         *
         * BT0  BT1  BT2  BT3  BT4  │  _    _    _    _    _
         * CLR  ALL   _    _    _   │  _    _    _    _   OUT
         *  _    _    _    _    _   │  _    _    _    _    _
         *             ×    ×    ×  │  _    ×    ×
         * ══════════════════════════════════════════════════════════ */

        bt_layer {
            bindings = <
&none  &bt BT_SEL 0  &bt BT_SEL 1    &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4    &none   &none  &none  &none  &none         &none
&none  &bt BT_CLR    &bt BT_CLR_ALL  &none         &none         &none           &none   &none  &none  &none  &out OUT_TOG  &none
&none  &none         &none           &none         &none         &none           &none   &none  &none  &none  &none         &none
                                     &none         &none         &none           &trans  &none  &none
            >;
        };
    };
};
